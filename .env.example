# ─── App ────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitpulse:gitpulse_dev@db:5432/gitpulse

# ─── GitHub OAuth App ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── AI Provider Chain ──────────────────────────────────────────────────────
# Format: comma-separated "<provider>:<api_key>"
# Supported: deepseek, groq, openai, anthropic, openrouter
# Tried in order — on any error moves to the next one silently.
#
# Free / cheap options:
#   deepseek   → https://platform.deepseek.com   (very cheap, great quality)
#   groq       → https://console.groq.com         (free tier, fast)
#   openrouter → https://openrouter.ai             (free models available)
#   openai     → https://platform.openai.com       (gpt-4o-mini)
#   anthropic  → https://console.anthropic.com     (claude-haiku)
#
AI_PROVIDERS=deepseek:sk-...,groq:gsk_...,openai:sk-...

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@gitpulse.io

# ─── Payments (Polar.sh) ────────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
