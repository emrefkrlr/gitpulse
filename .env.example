# ─── App ────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitpulse:gitpulse_dev@db:5432/gitpulse

# ─── GitHub OAuth App ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── AI Provider Chain ──────────────────────────────────────────────────────
# Format: comma-separated "<provider>:<api_key>"
# Supported: openai, anthropic, groq, openrouter
# System tries each in order; on any error (auth/rate-limit/quota) moves to next.
#
# Ücretsiz seçenekler:
#   groq      → https://console.groq.com         (ücretsiz, hızlı)
#   openrouter→ https://openrouter.ai             (ücretsiz modeller var)
#   openai    → https://platform.openai.com       (gpt-4o-mini ucuz)
#   anthropic → https://console.anthropic.com     (claude-haiku ucuz)
#
AI_PROVIDERS=openai:sk-...,groq:gsk_...,anthropic:sk-ant-...

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@gitpulse.io

# ─── Payments (Lemon Squeezy) ───────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
