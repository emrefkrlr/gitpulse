# ─── App ────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitpulse:gitpulse_dev@db:5432/gitpulse

# ─── GitHub OAuth App ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── AI Provider Chain ──────────────────────────────────────────────────────
# Format: comma-separated "<provider>:<api_key>"
# Supported: deepseek, groq, openai, anthropic, openrouter
AI_PROVIDERS=deepseek:sk-...,groq:gsk_...,openai:sk-...

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@gitpulse.io

# ─── Payments (Polar.sh) ────────────────────────────────────────────────────
# sandbox = test mode, production = live mode
POLAR_ENV=sandbox
POLAR_ACCESS_TOKEN=pat_sandbox_...
POLAR_WEBHOOK_SECRET=polar_whs_...
POLAR_STARTER_PRODUCT_ID=...
POLAR_PRO_PRODUCT_ID=...
